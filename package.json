{
  "name": "quantum-wave-interference",
  "version": "1.0.0-dev.0",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/phetsims/quantum-wave-interference.git"
  },
  "devDependencies": {
    "grunt": "~1.5.3"
  },
  "phet": {
    "requirejsNamespace": "QUANTUM_WAVE_INTERFERENCE",
    "simulation": true,
    "runnable": true,
    "generatedUnitTests": true,
    "supportedBrands": [
      "phet",
      "adapted-from-phet",
      "phet-io"
    ],
    "phet-io": {
      "validation": false
    },
    "simFeatures": {
      "supportsDynamicLocale": true,
      "supportsInteractiveDescription": true,
      "supportsInteractiveHighlights": true,
      "supportsSound": true
    },
    "supportsOutputJS": true,
    "screenNameKeys": [
      "QUANTUM_WAVE_INTERFERENCE/screen.experiment.name",
      "QUANTUM_WAVE_INTERFERENCE/screen.highIntensity.name",
      "QUANTUM_WAVE_INTERFERENCE/screen.singleParticles.name"
    ]
  }
}